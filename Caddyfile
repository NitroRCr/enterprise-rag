# 用户端（front）—— 端口 8080
:8080 {
	root * /srv/front

	# 反向代理后端 API
	@api path /api/*
	handle @api {
		reverse_proxy {$SERVER_URL}
	}

	# SPA 路由回退
	handle {
		try_files {path} /index.html
		file_server
	}
}

# 管理端（admin）—— 端口 8081
:8081 {
	root * /srv/admin

	# 反向代理后端 API
	@api path /api/*
	handle @api {
		reverse_proxy {$SERVER_URL}
	}

	# SPA 路由回退
	handle {
		try_files {path} /index.html
		file_server
	}
}
