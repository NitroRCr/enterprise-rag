{
  "name": "enterprise-rag",
  "version": "0.1.0",
  "description": "企业知识库 RAG 问答系统 - 基于 BM25 全文搜索的 Agentic RAG",
  "productName": "企业知识库",
  "author": "NitroRCr <i@krytro.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "test": "echo \"No test specified\" && exit 0",
    "dev:server": "bun run --hot src-server/index.ts",
    "dev:front": "TARGET_APP=front bun quasar dev",
    "dev:admin": "TARGET_APP=admin bun quasar dev",
    "build:server": "bun build src-server/index.ts --target bun --outdir ./dist/server",
    "build:front": "TARGET_APP=front bun quasar build",
    "build:admin": "TARGET_APP=admin bun quasar build",
    "generate:auth": "bunx --bun @better-auth/cli@latest generate --config src-server/auth/auth.ts --output src-server/schema/auth.gen.ts -y",
    "postinstall": "bun quasar prepare"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@hono/zod-validator": "^0.7.6",
    "@material/material-color-utilities": "^0.3.0",
    "@quasar/extras": "^1.16.4",
    "ai": "^6.0.116",
    "better-auth": "^1.5.4",
    "dexie": "^4.0.11",
    "drizzle-orm": "^0.44.2",
    "fflate": "^0.8.2",
    "hono": "^4.9.11",
    "mammoth": "^1.11.0",
    "md-editor-v3": "^6.4.1",
    "neostandard": "^0.12.2",
    "pinia": "^3.0.1",
    "quasar": "^2.16.0",
    "unpdf": "^1.3.2",
    "vue": "^3.5.20",
    "vue-router": "^4.0.12",
    "xlsx-republish": "^0.20.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@quasar/app-vite": "^2.3.0",
    "@types/bun": "^1.1.14",
    "@types/node": "^20.5.9",
    "@unocss/preset-rem-to-px": "^66.5.1",
    "@vue/eslint-config-typescript": "^14.4.0",
    "autoprefixer": "^10.4.2",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^9.30.0",
    "globals": "^15.12.0",
    "typescript": "~5.5.3",
    "unocss": "^66.5.1",
    "vite-plugin-checker": "^0.9.0",
    "vue-tsc": "^2.0.29"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20 || ^18",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
